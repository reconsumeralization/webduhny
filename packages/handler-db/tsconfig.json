{
  "extends": "../../tsconfig.json",
  "include": ["src", "__tests__"],
  "references": [{ "path": "../api-core" }, { "path": "../db" }],
  "compilerOptions": {
    "rootDirs": ["./src", "./__tests__"],
    "outDir": "./dist",
    "declarationDir": "./dist",
    "paths": {
      "~/*": ["./src/*"],
      "~tests/*": ["./__tests__/*"],
      "@webiny/api-core/*": ["../api-core/src/*"],
      "@webiny/api-core": ["../api-core/src"],
      "@webiny/db/*": ["../db/src/*"],
      "@webiny/db": ["../db/src"]
    },
    "baseUrl": "."
  }
}
